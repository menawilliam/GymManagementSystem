@model MemberViewModel
@{
    ViewData["Title"] = "Member Data";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card card-details border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- 🔵 Header -->
                <div class="bg-primary text-white text-center py-4 position-relative">
                    <img src="~/images/members/@Model.Photo"
                         class="rounded-circle shadow"
                         style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #fff;" />

                    <h3 class="mt-3 mb-1">@Model.Name</h3>
                    <span class="badge bg-light text-dark px-3 py-2">
                        @(Model.PlanName ?? "No Active Plan")
                    </span>
                </div>

                <!-- 🧾 Member Info -->
                <div class="card-body p-4">

                    <div class="row g-3">

                        <div class="col-12">
                            <div class="info-box">
                                <i class="bi bi-envelope"></i>
                                <div>
                                    <small>Email</small>
                                    <strong>@Model.Email</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="info-box">
                                <i class="bi bi-telephone"></i>
                                <div>
                                    <small>Phone</small>
                                    <strong>@Model.Phone</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-box">
                                <i class="bi bi-gender-ambiguous"></i>
                                <div>
                                    <small>Gender</small>
                                    <strong>@Model.Gender</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-box">
                                <i class="bi bi-calendar"></i>
                                <div>
                                    <small>Date of Birth</small>
                                    <strong>@Model.DateOfBirth</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-box">
                                <i class="bi bi-calendar-check"></i>
                                <div>
                                    <small>Start Date</small>
                                    <strong>@Model.MembershipStratDate</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-box">
                                <i class="bi bi-calendar-x"></i>
                                <div>
                                    <small>End Date</small>
                                    <strong>@Model.MembershipEndDate</strong>
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="info-box">
                                <i class="bi bi-geo-alt"></i>
                                <div>
                                    <small>Address</small>
                                    <strong>@(Model.Address ?? "No Address")</strong>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- 🔥 Body Stats -->
                    @if (Model.BMI != null)
                    {
                        <div class="card mt-4 shadow-sm">
                            <div class="card-body text-center">

                                <h5 class="card-title mb-3">🔥 Body Stats</h5>

                                <div class="row">
                                    <div class="col-md-4">
                                        <h6>BMI</h6>
                                        <p class="fw-bold">@Model.BMI</p>
                                    </div>

                                    <div class="col-md-4">
                                        <h6>TDEE</h6>
                                        <p class="fw-bold">@Model.TDEE kcal</p>
                                    </div>

                                    <div class="col-md-4">
                                        <h6>Maintenance</h6>
                                        <p class="fw-bold">@Model.MaintenanceCalories kcal</p>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <div class="text-center mt-3">
                            <a asp-controller="CalorieCalculator"
                               asp-action="RecalculateForMember"
                               asp-route-memberId="@Model.Id"
                               class="btn btn-primary">
                                🔄 Recalculate
                            </a>
                        </div>
                    }

                    <!-- 📜 History + 📈 Chart -->
                    @if (Model.BodyStatsHistory != null && Model.BodyStatsHistory.Any())
                    {
                        <div class="card mt-4 shadow-sm">
                            <div class="card-body">

                                <h5 class="card-title mb-3">📜 Body Stats History</h5>

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th>Date</th>
                                                <th>Weight</th>
                                                <th>BMI</th>
                                                <th>TDEE</th>
                                                <th>Maintenance</th>
                                                <th>Cutting</th>
                                                <th>Bulking</th>
                                                <th>Action</th> <!-- 🔥 تمت الإضافة -->
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in Model.BodyStatsHistory)
                                            {
                                                <tr>
                                                    <td>@item.CalculatedAt.ToString("dd/MM/yyyy hh:mm tt")</td>
                                                    <td>@item.WeightKg</td>
                                                    <td>@item.BMI</td>
                                                    <td>@item.TDEE</td>
                                                    <td>@item.MaintenanceCalories</td>
                                                    <td>@item.CuttingCalories</td>
                                                    <td>@item.BulkingCalories</td>

                                                    <td>
                                                        <form asp-action="DeleteBodyStat" method="post"
                                                              onsubmit="return confirm('Are you sure you want to delete this record?');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="bodyStatId" value="@item.Id" />
                                                            <input type="hidden" name="memberId" value="@Model.Id" />
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                Delete
                                                            </button>
                                                        </form>
                                                    </td>

                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                                <!-- 📈 Chart -->
                                <h5 class="card-title mt-4 mb-3">📈 Progress Chart</h5>
                                <canvas id="memberStatsChart" height="100"></canvas>

                            </div>
                        </div>
                    }

                </div>

                <!-- 🔘 Footer -->
                <div class="card-footer bg-white border-0 p-3">
                    <a asp-action="Index" class="btn btn-outline w-100">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const ctx = document.getElementById("memberStatsChart");
            if (!ctx) return;

            const labels = [
                @Html.Raw(string.Join(",", Model.BodyStatsHistory.Select(x => $"'{x.CalculatedAt:dd/MM}'")))
            ];

            const bmiData = [
                @Html.Raw(string.Join(",", Model.BodyStatsHistory.Select(x => x.BMI.ToString(System.Globalization.CultureInfo.InvariantCulture))))
            ];

            const weightData = [
                @Html.Raw(string.Join(",", Model.BodyStatsHistory.Select(x => x.WeightKg.ToString(System.Globalization.CultureInfo.InvariantCulture))))
            ];

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'BMI',
                            data: bmiData,
                            borderWidth: 2,
                            tension: 0.3
                        },
                        {
                            label: 'Weight (kg)',
                            data: weightData,
                            borderWidth: 2,
                            tension: 0.3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'top'
                        }
                    }
                }
            });
        });
    </script>
}